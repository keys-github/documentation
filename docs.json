{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "LambdaTest",
  "colors": {
    "primary": "#c24e00",
    "light": "#c24e00",
    "dark": "#c24e00"
  },
  "favicon": "/favicon.ico",
  "appearance": {
    "default": "light"
  },
  "seo": {
    "metatags": {
      "robots": "noindex, nofollow"
    }
  },
  "fonts": {
    "heading": {
      "family": "SF Pro, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif"
    },
    "body": {
      "family": "SF Pro, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif"
    }
  },
  "openapi": [
    "support-openapi.yaml",
    "mobile_automation.yaml",
    "Smart-UI.yaml",
    "accessibility-testing.yaml",
    "analytics-openapi.yaml"
  ],
  "api": {
    "playground": {
      "proxy": false
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open-lines",
        "pages": [
          {
            "group": "Kane CLI",
            "pages": [
              "docs/index",
              {
                "group": "Getting Started",
                "pages": [
                  "docs/kane-cli-installation",
                  "docs/kane-cli-quickstart",
                  "docs/kane-cli-authentication"
                ]
              },
              {
                "group": "Core Concepts",
                "pages": [
                  "docs/kane-cli-modes",
                  "docs/kane-cli-configuration",
                  "docs/kane-cli-writing-objectives",
                  "docs/kane-cli-variables-and-context"
                ]
              },
              {
                "group": "Integrations & Automation",
                "pages": [
                  "docs/kane-cli-tms-integration",
                  "docs/kane-cli-cicd",
                  "docs/kane-cli-parallel-execution"
                ]
              },
              {
                "group": "Agent Mode",
                "pages": [
                  "docs/kane-cli-agent-mode",
                  "docs/kane-cli-skills"
                ]
              },
              {
                "group": "Reference",
                "pages": [
                  "docs/kane-cli-cli-reference",
                  "docs/kane-cli-error-codes",
                  "docs/kane-cli-troubleshooting",
                  "docs/kane-cli-changelog"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "href": "https://status.lambdatest.io/",
          "icon": "signal"
        },
        {
          "anchor": "Community",
          "href": "https://community.testmuai.com/",
          "icon": "users"
        },
        {
          "anchor": "Blog",
          "href": "https://www.testmuai.com/blog/",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://www.testmuai.com/"
  },
  "navbar": {
    "links": [
      {
        "label": "Github",
        "href": "https://github.com/LambdaTest",
        "icon": "github"
      },
      {
        "label": "Login",
        "href": "https://accounts.lambdatest.com/login?_gl=1*il1bzu*_gcl_au*MTAzNzUyNzAwMC4xNzYxODg2NjEy"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started Free",
      "href": "https://accounts.lambdatest.com/register?_gl=1*il1bzu*_gcl_au*MTAzNzUyNzAwMC4xNzYxODg2NjEy"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "feedback": {
    "thumbsRating": false,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-5M2PF5TP"
    },
    "telemetry": {
      "enabled": false
    }
  },
  "footer": {
    "socials": {
      "facebook": "https://www.facebook.com/testmuai/",
      "x": "https://x.com/testmuai",
      "github": "https://github.com/LambdaTest/",
      "linkedin": "https://www.linkedin.com/company/testmu-ai",
      "youtube": "https://www.youtube.com/@TestMuAI"
    }
  },
  "redirects": [
    {
      "source": "/docs/:slug",
      "destination": "/docs/:slug/"
    },
    {
      "source": "/support/api-doc/:path/:slug/",
      "destination": "/support/api-doc/:path/:slug"
    },
    {
      "source": "/support/api-doc/:slug/",
      "destination": "/support/api-doc/:slug"
    },
    {
      "source": "/docs/scim/okta",
      "destination": "/docs/scim-okta"
    },
    {
      "source": "/docs/scim/azure",
      "destination": "/docs/scim-azure"
    }
  ]
}